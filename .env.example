# ============================================================
# CHIMI — config de entorno
# Copialo a .env (no commitear) y completá los valores reales.
# ============================================================

# ---------- MySQL (DB externa, ya existente en el server) ----------
MYSQL_HOST=mysql.internal
MYSQL_PORT=3306
MYSQL_DATABASE=chimi
MYSQL_USER=chimi_app
MYSQL_PASSWORD=changeme
MYSQL_USE_SSL=false
# JDBC se arma como: jdbc:mysql://${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}

# ---------- Seguridad ----------
# Genera con: openssl rand -base64 48
JWT_SECRET=cambia-esto-por-uno-de-48-bytes-en-base64
JWT_EXPIRATION_MINUTES=480

# ---------- WhatsApp Cloud API (Meta) ----------
WPP_VERIFY_TOKEN=token-que-vos-elegis-y-le-pasas-a-meta
WPP_ACCESS_TOKEN=EAAG...           # token permanente del system user
WPP_PHONE_NUMBER_ID=               # ID del número de WhatsApp Business
WPP_BUSINESS_ACCOUNT_ID=           # WABA ID
WPP_API_VERSION=v21.0
WPP_GRAPH_BASE_URL=https://graph.facebook.com

# ---------- Comunicación interna entre servicios ----------
# El wpp-worker llama a la API por la red interna del compose
API_INTERNAL_URL=http://chimi-api:8080
# Shared secret para autenticar wpp-worker -> api
INTERNAL_API_KEY=otra-cosa-larga-y-aleatoria

# ---------- Puertos expuestos en el host (los rutea tu reverse proxy) ----------
API_HOST_PORT=18080
WPP_WORKER_HOST_PORT=18081
FRONT_HOST_PORT=18082

# ---------- Frontend: dónde se va a servir el dashboard ----------
# Si lo metés bajo gateway.liro.pet/chimi → VITE_BASE_PATH=/chimi/  y  VITE_API_BASE_URL=/chimi/api
# Si lo ponés en un subdominio dedicado   → VITE_BASE_PATH=/        y  VITE_API_BASE_URL=/api
# Estos valores se leen al BUILDEAR la imagen del front, no en runtime.
VITE_BASE_PATH=/chimi/
VITE_API_BASE_URL=/chimi/api

# ---------- Logging / runtime ----------
SPRING_PROFILES_ACTIVE=prod
TZ=America/Argentina/Buenos_Aires
JAVA_OPTS=-XX:MaxRAMPercentage=75 -XX:+UseG1GC
